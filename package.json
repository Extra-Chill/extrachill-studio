{
	"name": "extrachill-studio",
	"version": "0.1.0",
	"description": "Internal studio tooling for the Extra Chill team.",
	"private": true,
	"scripts": {
		"build": "wp-scripts build && npm run copy:block-files",
		"copy:block-files": "cp blocks/studio/block.json blocks/studio/render.php blocks/studio/style.css dist/studio/",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@extrachill/chat": "file:../chat",
		"@extrachill/components": "file:../extrachill-components",
		"@extrachill/tokens": "^0.1.0"
	},
	"devDependencies": {
		"@extrachill/api-client": "file:../extrachill-api-client",
		"@types/wordpress__block-editor": "^15.0.5",
		"@types/wordpress__blocks": "^15.10.2",
		"@wordpress/scripts": "^31.1.0",
		"typescript": "^5.7.0"
	}
}
